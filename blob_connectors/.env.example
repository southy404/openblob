# Blob Connectors — Environment variables
# Copy: cp .env.example .env
# Only fill in the connectors you want to use, leave the rest empty.

# ──────────────────────────────────────────
# TELEGRAM
# Get it from: https://t.me/BotFather → /newbot
# ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ──────────────────────────────────────────
# SLACK
# Bot Token:  api.slack.com/apps → OAuth & Permissions → xoxb-…
# App Token:  api.slack.com/apps → Basic Information → App-Level Tokens → xapp-…
# ──────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ──────────────────────────────────────────
# DISCORD
# Get it from: discord.com/developers/applications → Bot → Token
# Important: enable "Message Content Intent" in the portal!
# ──────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ──────────────────────────────────────────
# EMAIL (Gmail example)
# App password: myaccount.google.com/apppasswords
# Do not use your normal password — only app passwords work!
# ──────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_HOST=imap.gmail.com
SMTP_HOST=smtp.gmail.com
IMAP_PORT=993
SMTP_PORT=587