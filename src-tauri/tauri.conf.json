{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "companion-v1",
  "version": "0.1.0",
  "identifier": "com.davide.companionv1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "companion-v1",
        "width": 260,
        "height": 260,
        "minWidth": 230,
        "minHeight": 260,
        "maxWidth": 260,
        "maxHeight": 260,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": false,
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
